# MYAS Task Tracker — sample environment
# Copy this file to .env and fill in real values.
# Never commit .env. Never share secrets in chat.
# ---------------------------------------------------------------

# -- Database (Postgres) --
# Local Postgres:
#   postgresql://postgres:postgres@localhost:5432/myas?schema=public
#
# Neon (managed) — RUNTIME / pooled connection (used by the app):
#   postgresql://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&pgbouncer=true&connect_timeout=15
DATABASE_URL=""

# Neon (managed) — DIRECT / unpooled connection (used by prisma migrate / introspect).
# Drop "-pooler" from the host, drop pgbouncer=true. Leave blank when using local Postgres.
#   postgresql://<user>:<password>@<project>.<region>.aws.neon.tech/<db>?sslmode=require&connect_timeout=15
DIRECT_URL=""


# -- NextAuth (Auth.js v5) --
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Optional in dev (auto-detects); set explicitly when deploying.
AUTH_URL="http://localhost:3000"
# Set to true when behind a reverse proxy / on a non-localhost host.
AUTH_TRUST_HOST="true"


# -- Object storage (S3-compatible) --
# Local dev (MinIO in Docker — see README "Local development"):
#   S3_ENDPOINT=http://localhost:9000
#   S3_REGION=us-east-1
#   S3_BUCKET=myas-attachments
#   S3_ACCESS_KEY=minioadmin
#   S3_SECRET_KEY=minioadmin
#   S3_FORCE_PATH_STYLE=true
#
# Production (AWS S3, ap-south-1 Mumbai):
#   S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
#   S3_REGION=ap-south-1
#   S3_BUCKET=myas-attachments-prod
#   S3_ACCESS_KEY=<IAM access key>
#   S3_SECRET_KEY=<IAM secret>
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=""
S3_REGION="ap-south-1"
S3_BUCKET="myas-attachments"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_FORCE_PATH_STYLE="true"

# How long signed download URLs stay valid (seconds).
S3_PRESIGN_TTL_SECONDS="3600"


# -- Bootstrap Super Admin (used only by prisma/seed.ts) --
# The first account created in the database. After seeding, change
# the password from the profile screen and never reuse this value.
BOOTSTRAP_USERNAME="osd.myas"
BOOTSTRAP_PASSWORD="ChangeMeImmediately!"
BOOTSTRAP_NAME="OSD"


# -- Google Analytics (GA4 Data API) --
# Required to show live active/total user counts in the header.
# Leave blank to hide the badge — the app works fine without it.
#
# 1. Enable "Google Analytics Data API" in Google Cloud Console
# 2. Create a Service Account, download the JSON key
# 3. Add the service account email as Viewer in GA4 Admin → Property Access
# 4. GA4_PROPERTY_ID: found in GA4 Admin → Property Settings (numeric)
# 5. GA4_CLIENT_EMAIL: the "client_email" field from the JSON key
# 6. GA4_PRIVATE_KEY: the "private_key" field from the JSON key (keep the \n)
GA4_PROPERTY_ID=""
GA4_CLIENT_EMAIL=""
GA4_PRIVATE_KEY=""


# -- App --
APP_TIMEZONE="Asia/Kolkata"
NODE_ENV="development"
